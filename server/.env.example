# Environment Variables — PawLink Backend
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Server
PORT=5000
NODE_ENV=development

# MySQL Database (XAMPP defaults)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=pawlink_db

# JWT
JWT_SECRET=pawlink_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=24h

# File Uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=5
